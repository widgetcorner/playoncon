# Copy this file to scripts/.env.local and fill in the values.
# scripts/.env.local is git-ignored — never commit it.
# The build scripts (build-testflight.sh, build-play.sh) `source` this file
# to pull secrets out of the committed shell scripts.

# Google Sheets API v4 key (project: playoncon). Restricted to Sheets API
# only. Rotate in GCP Console → APIs & Credentials if this ever leaks.
SHEETS_API_KEY="paste-rotated-key-here"

# Supabase publishable key (safe to expose by design — the "publishable"
# prefix means it's meant to ship in clients — but kept here for
# consistency and easy rotation).
SUPABASE_PUBLISHABLE_KEY="paste-supabase-publishable-key-here"
